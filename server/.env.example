POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=tonton
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_CONTAINER_NAME=postgres_db_tonton
POSTGRES_IMAGE=postgres:latest

SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_OPEN_IN_VIEW=false

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_HEADERS=*
APP_CORS_EXPOSED_HEADERS=Content-Type
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_MAX_AGE=3600

APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
APP_JWT_REFRESH_TOKEN_EXPIRATION_MS=2592000000

APP_AUTH_COOKIE_REFRESH_TOKEN_NAME=refresh_token
APP_AUTH_COOKIE_PATH=/
APP_AUTH_COOKIE_DOMAIN=
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_AUTH_COOKIE_SECURE=false

APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_PASSWORD=change-me
APP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
APP_BOOTSTRAP_ADMIN_FULL_NAME=Your Name
APP_BOOTSTRAP_ADMIN_PHONE_NUMBER=0123456789

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_DEFAULT_FOLDER=tonton


